[Unit]
Description=Daily encrypted-key verification for fitness-agent
Requires=fitness-agent-verify-keys.service

[Timer]
# 03:30 local time every day; Persistent=true catches missed runs after
# a host reboot.
OnCalendar=*-*-* 03:30:00
Persistent=true
RandomizedDelaySec=5m

[Install]
WantedBy=timers.target
