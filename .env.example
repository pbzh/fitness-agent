# Database
# Local dev matches docker-compose.yml. For Proxmox, replace localhost with the DB LXC IP.
DATABASE_URL=postgresql+asyncpg://fitness:fitness@localhost:5432/fitness

# Auth
# Generate a real value with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-generate-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Local LLM (llama.cpp OpenAI-compatible endpoint)
LOCAL_LLM_BASE_URL=http://localhost:8080/v1
LOCAL_LLM_MODEL=qwen3-32b-q4
LOCAL_LLM_API_KEY=not-needed

# Cloud LLM keys (leave blank to disable that provider)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3

# Per-task routing: local | anthropic | openai
PROVIDER_FOR_CHAT=local
PROVIDER_FOR_PLANNING=anthropic
PROVIDER_FOR_NUTRITION=anthropic
PROVIDER_FOR_PROGRESS=anthropic

# External integrations
GARMIN_EMAIL=
GARMIN_PASSWORD=
GOOGLE_CALENDAR_ID=

LOG_LEVEL=INFO
TIMEZONE=Europe/Zurich
SCHEDULER_USER_ID=00000000-0000-0000-0000-000000000001
